#include "nowi_cellular_nrf9151_common-pinctrl.dtsi"
#include "nowi_cellular_nrf9151-partitioning.dtsi"

/ {
    model = "NOWi Cellular Board";
    compatible = "nowi,nowi-cellular";

    chosen {
        zephyr,console = &uart0;
        zephyr,shell-uart = &uart0;
        zephyr,uart-mcumgr = &uart0;
        nordic,modem-trace-uart = &uart0;
    };

    leds {
        compatible = "gpio-leds";

        red_led: led_0 {
            gpios = <&gpio0 10 GPIO_ACTIVE_LOW>;
            label = "Red LED";
        };

        green_led: led_1 {
            gpios = <&gpio0 11 GPIO_ACTIVE_LOW>;
            label = "Green LED";
        };

        blue_led: led_2 {
            gpios = <&gpio0 12 GPIO_ACTIVE_LOW>;
            label = "Blue LED";
        };
    };

    aliases {
        successled = &green_led;
		infoled = &blue_led;
		errorled = &red_led;
        watchdog0 = &wdt0;
        power-button = &power_button;
    };

    magnetometer {
		compatible = "gpio-keys";
		magpower: mag_power {
			gpios = <&gpio0 0 (GPIO_ACTIVE_HIGH)>;
			label = "Sensor 1 power pin";
		};
		magint: mag_int {
			gpios = <&gpio0 2 (GPIO_ACTIVE_HIGH)>;
			label = "Sensor 1 interrupt pin";
		};
        mag2power: mag2_power {
			gpios = <&gpio0 4 (GPIO_ACTIVE_HIGH)>;
			label = "Sensor 2 power pin";
		};
		mag2int: mag2_int {
			gpios = <&gpio0 3 (GPIO_ACTIVE_HIGH)>;
			label = "Sensor 2 interrupt pin";
		};
	};

    buttons {
        compatible = "gpio-keys";
        power_button: button_0 {
            gpios = <&gpio0 14 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
            label = "Power Button";
        };
    };
};

&gpiote {
    status = "okay";
};

&gpio0 {
    status = "okay";
};

&wdt0 {
    status = "okay";
};

&uart0 {
    status = "okay";
    current-speed = <115200>;
    pinctrl-0 = <&uart0_default>;
    pinctrl-1 = <&uart0_sleep>;
    pinctrl-names = "default", "sleep";
};

buzz_pwm_inst: &pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_buzz_default>;
	pinctrl-1 = <&pwm0_buzz_sleep>;
	pinctrl-names = "default", "sleep";
};

/ {
	pwmleds {
		compatible = "pwm-leds";
		buzzpwm: pwm_led_0 {
			pwms = <&pwm0 0 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
			label = "Buzzer PWM";
		};
	};

	aliases {
		buzzpwm = &buzzpwm;
	};
};

/* CRITICAL FIX: mag1 and mag2 must be labels for the I2C buses, not child devices
 * This matches what we learned from the nrf9151dk overlay migration:
 * - mag1: &i2c1 means "mag1 is an alias for i2c1 bus"
 * - Code uses DT_NODELABEL(mag1) which needs to resolve to the bus device
 */
mag1: &i2c1 {
    compatible = "nordic,nrf-twim";
    status = "okay";
    pinctrl-0 = <&i2c1_default>;
    pinctrl-1 = <&i2c1_sleep>;
    pinctrl-names = "default", "sleep";
    clock-frequency = <I2C_BITRATE_FAST>;
};

mag2: &i2c2 {
    compatible = "nordic,nrf-twim";
    status = "okay";
    pinctrl-0 = <&i2c2_default>;
    pinctrl-1 = <&i2c2_sleep>;
    pinctrl-names = "default", "sleep";
    clock-frequency = <I2C_BITRATE_FAST>;
};
